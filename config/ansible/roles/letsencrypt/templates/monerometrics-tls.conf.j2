
{% if letsencrypt_cloudflare_only | default(true) %}
geo $mm_origin_allowed {
    default 0;
    173.245.48.0/20 1;
    103.21.244.0/22 1;
    103.22.200.0/22 1;
    103.31.4.0/22 1;
    141.101.64.0/18 1;
    108.162.192.0/18 1;
    190.93.240.0/20 1;
    188.114.96.0/20 1;
    197.234.240.0/22 1;
    198.41.128.0/17 1;
    162.158.0.0/15 1;
    104.16.0.0/13 1;
    104.24.0.0/14 1;
    172.64.0.0/13 1;
    131.0.72.0/22 1;
    2400:cb00::/32 1;
    2606:4700::/32 1;
    2803:f800::/32 1;
    2405:b500::/32 1;
    2405:8100::/32 1;
    2a06:98c0::/29 1;
    2c0f:f248::/32 1;
    100.64.0.0/10 1;
    10.0.0.0/8 1;
    127.0.0.1/32 1;
    ::1/128 1;
}
{% endif %}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;
    return 444;
}

server {
    listen 80;
    listen [::]:80;

    server_name {{ letsencrypt_domain }} www.{{ letsencrypt_domain }} api.{{ letsencrypt_domain }};

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
        default_type "text/plain";
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl default_server;
    listen [::]:443 ssl default_server;
    ssl_reject_handshake on;
}

server {
{% if letsencrypt_http2_enabled | default(false) %}
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
{% else %}
    listen 443 ssl;
    listen [::]:443 ssl;
{% endif %}

    include /etc/nginx/modsec-enable.conf*;

    server_name {{ letsencrypt_domain }} www.{{ letsencrypt_domain }};

{% if letsencrypt_cloudflare_only | default(true) %}
    if ($mm_origin_allowed = 0) { return 444; }
{% endif %}

    ssl_certificate {{ letsencrypt_cert_dir }}/fullchain.pem;
    ssl_certificate_key {{ letsencrypt_cert_dir }}/privkey.pem;
    ssl_trusted_certificate {{ letsencrypt_cert_dir }}/chain.pem;

    ssl_protocols TLSv1.3 TLSv1.2;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=15768000; includeSubDomains" always;

    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
    add_header Content-Security-Policy "frame-ancestors 'none'" always;
{% if tor_onion_hostname | default('') %}
    add_header Onion-Location "http://{{ tor_onion_hostname }}$request_uri" always;
{% endif %}

    root /var/www/monerometrics;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location = /healthz {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }
}

server {
{% if letsencrypt_http2_enabled | default(false) %}
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
{% else %}
    listen 443 ssl;
    listen [::]:443 ssl;
{% endif %}

    include /etc/nginx/modsec-enable.conf*;

    server_name api.{{ letsencrypt_domain }};

{% if letsencrypt_cloudflare_only | default(true) %}
    if ($mm_origin_allowed = 0) { return 444; }
{% endif %}

    ssl_certificate {{ letsencrypt_cert_dir }}/fullchain.pem;
    ssl_certificate_key {{ letsencrypt_cert_dir }}/privkey.pem;
    ssl_trusted_certificate {{ letsencrypt_cert_dir }}/chain.pem;
    ssl_protocols TLSv1.3 TLSv1.2;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=15768000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;

    location / {
        proxy_pass {{ letsencrypt_api_upstream }};
        proxy_http_version 1.1;
        proxy_set_header Host api.{{ letsencrypt_domain }};
        proxy_set_header X-MM-Onion "";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;
    }
}
