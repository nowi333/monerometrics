# {{ ansible_managed }}
# Configuration nginx avec TLS Let's Encrypt
# Wildcard cert *.monerometrics.net + apex

# === Server HTTP : redirige tout vers HTTPS sauf ACME challenge ===
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name {{ letsencrypt_domain }} www.{{ letsencrypt_domain }};

    # ACME challenge HTTP-01 (fallback si DNS-01 indispo)
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
        default_type "text/plain";
        try_files $uri =404;
    }

    # Tout le reste : redirect 301 vers HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# === Server HTTPS : sert la page ===
server {
{% if letsencrypt_http2_enabled | default(false) %}
    listen 443 ssl http2 default_server;
    listen [::]:443 ssl http2 default_server;
{% else %}
    # HTTP/2 desactive au niveau origin : la lib ModSecurity v3 packagee Ubuntu
    # (libmodsecurity3) segfault (SIGSEGV / signal 11) sur certaines requetes
    # HTTP/2 via le connecteur nginx. Cloudflare (proxy actif) sert HTTP/2 et
    # HTTP/3 aux clients ; la liaison Cloudflare -> origin reste en HTTP/1.1,
    # ce qui evite le crash tout en gardant le WAF pleinement actif.
    # Ne reactiver (letsencrypt_http2_enabled: true) qu'apres avoir remplace
    # libmodsecurity par une version corrigee et re-teste les 5 familles d'attaque.
    listen 443 ssl default_server;
    listen [::]:443 ssl default_server;
{% endif %}

    # Module WAF charge dynamiquement si le role modsecurity est applique.
    # Le glob '*' tolere l'absence du fichier.
    include /etc/nginx/modsec-enable.conf*;

    server_name {{ letsencrypt_domain }} www.{{ letsencrypt_domain }};

    # === TLS configuration ===
    ssl_certificate {{ letsencrypt_cert_dir }}/fullchain.pem;
    ssl_certificate_key {{ letsencrypt_cert_dir }}/privkey.pem;
    ssl_trusted_certificate {{ letsencrypt_cert_dir }}/chain.pem;

    # Modern TLS profile (Mozilla 2025)
    ssl_protocols TLSv1.3 TLSv1.2;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    # OCSP stapling : navigateur peut verifier la revocation du cert

    # HSTS : force HTTPS pour les 6 prochains mois
    add_header Strict-Transport-Security "max-age=15768000; includeSubDomains" always;

    # Autres headers securite
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    root /var/www/monerometrics;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location = /healthz {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }
}

# === Server HTTPS : API (reverse proxy vers Traefik dans le cluster k3s) ===
# api.<domaine> n'est PAS servi en statique : il est relaye vers l'API FastAPI
# exposee par Traefik (IngressRoute Host(api.<domaine>) sur l'entryPoint web).
server {
{% if letsencrypt_http2_enabled | default(false) %}
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
{% else %}
    listen 443 ssl;
    listen [::]:443 ssl;
{% endif %}

    # WAF actif aussi sur l'API (defense en profondeur ; trafic GET only).
    include /etc/nginx/modsec-enable.conf*;

    server_name api.{{ letsencrypt_domain }};

    # Meme certificat wildcard *.{{ letsencrypt_domain }}
    ssl_certificate {{ letsencrypt_cert_dir }}/fullchain.pem;
    ssl_certificate_key {{ letsencrypt_cert_dir }}/privkey.pem;
    ssl_trusted_certificate {{ letsencrypt_cert_dir }}/chain.pem;
    ssl_protocols TLSv1.3 TLSv1.2;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=15768000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;

    location / {
        proxy_pass {{ letsencrypt_api_upstream }};
        proxy_http_version 1.1;
        proxy_set_header Host api.{{ letsencrypt_domain }};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 30s;
    }
}
