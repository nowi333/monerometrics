# ============================================================
# Terraform
# ============================================================
# State files - NE JAMAIS COMMITTER (contient des secrets)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan files - peuvent contenir des secrets
*.tfplan
*.plan

# Variables locales avec secrets
*.tfvars
!*.example.tfvars
.terraformrc
terraform.rc

# Provider plugins et caches
.terraform/
.terraform.lock.hcl.bak
crash.log
crash.*.log

# ============================================================
# Ansible
# ============================================================
*.retry
.vault_pass
.ansible/
ansible.log

# Vault passwords et clés
vault-password*
*.vault
.vault_pass*

# ============================================================
# Kubernetes
# ============================================================
kubeconfig*
*.kubeconfig
.kube/

# Secrets manifests (doivent passer par Vault/OpenBao)
**/secrets-*.yaml
**/secret-*.yaml
!**/secret-template.yaml

# Helm
charts/*.tgz

# ============================================================
# Secrets et credentials génériques
# ============================================================
*.pem
*.key
*.crt
*.p12
*.pfx
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
id_rsa*
id_ed25519*
.ssh/
credentials.json
service-account*.json
azure-credentials*

# Variables d'environnement
.env
.env.*
!.env.example

# ============================================================
# Système d'exploitation
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================================
# Éditeurs
# ============================================================
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.cursor/

# ============================================================
# Builds et artefacts
# ============================================================
dist/
build/
out/
*.log
*.tmp

# ============================================================
# Python (pour scripts ponctuels)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/

# ============================================================
# Node (au cas où on ajoute un dashboard)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*

# ============================================================
# Documentation - exports temporaires
# ============================================================
docs/captures/.tmp/
*.draft.md

# Fichiers parasites / locaux
nohup.out
*.bak
*.tfplan
