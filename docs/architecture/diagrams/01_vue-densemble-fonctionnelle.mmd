flowchart TB
    Internet([Internet - Utilisateurs publics])
    Admin([Administrateur])

    subgraph Cloud["Microsoft Azure - Region France Central"]
        direction TB

        subgraph Edge["Zone Edge - Filtrage et exposition"]
            direction TB
            FW["OPNsense<br/>Pare-feu stateful<br/>Suricata IDS IPS"]
            RP["nginx<br/>Reverse proxy<br/>WAF ModSecurity<br/>TLS 1.3"]
            FW --> RP
        end

        subgraph App["Zone Applicative"]
            K8S["Cluster k3s<br/>1 master 2 workers<br/>API et Dashboard Monero"]
        end

        subgraph Data["Zone Donnees"]
            direction TB
            Mon["monerod prune<br/>Detection de reorg"]
            DB["PostgreSQL Patroni<br/>Donnees indexees"]
        end

        subgraph Mgmt["Zone Administration"]
            direction TB
            BAS["Bastion SSH<br/>Acces unique"]
            IdP["Authentik IdP<br/>OIDC plus MFA TOTP"]
            OBao["OpenBao<br/>Gestion des secrets"]
        end

        subgraph Obs["Zone Observabilite"]
            direction TB
            SIEM["Wazuh Manager<br/>SIEM HIDS XDR"]
            Mon2["Prometheus Grafana<br/>Loki Alloy"]
        end

        Backup["Sauvegardes Restic<br/>Vers Azure Blob"]
    end

    Internet ==>|HTTPS 443| FW
    RP ==>|HTTPS interne| K8S
    K8S -->|RPC| Mon
    K8S -->|SQL| DB
    Admin ==>|SSH chiffre| BAS
    BAS --> IdP
    OBao -.->|Secrets| App
    OBao -.->|Secrets| Data
    SIEM -.->|Agents| Edge
    SIEM -.->|Agents| App
    SIEM -.->|Agents| Data
    SIEM -.->|Agents| Mgmt
    Data --> Backup
    App --> Backup

    classDef edge fill:#FAECE7,stroke:#993C1D,color:#4A1B0C
    classDef app fill:#E1F5EE,stroke:#0F6E56,color:#04342C
    classDef data fill:#FBEAF0,stroke:#993556,color:#4B1528
    classDef mgmt fill:#FAEEDA,stroke:#854F0B,color:#412402
    classDef obs fill:#EEEDFE,stroke:#3C3489,color:#26215C
    classDef ext fill:#E6F1FB,stroke:#185FA5,color:#042C53
    classDef bkp fill:#F1EFE8,stroke:#444441,color:#2C2C2A

    class FW,RP edge
    class K8S app
    class Mon,DB data
    class BAS,IdP,OBao mgmt
    class SIEM,Mon2 obs
    class Internet,Admin ext
    class Backup bkp
