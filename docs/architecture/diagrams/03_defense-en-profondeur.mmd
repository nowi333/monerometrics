flowchart TB
    Attacker([Attaquant Internet hostile])

    subgraph L1["Couche 1 - Perimetre reseau"]
        direction LR
        FW["OPNsense<br/>Pare-feu stateful"]
        IDS["Suricata IDS IPS<br/>Detection signatures"]
        GEO["Geo-blocking<br/>Filtrage IP"]
    end

    subgraph L2["Couche 2 - Application web"]
        direction LR
        WAF["ModSecurity WAF<br/>OWASP CRS 4.25 LTS"]
        TLS["TLS 1.3 obligatoire<br/>HSTS preload"]
        CRS["CrowdSec<br/>Threat intel partagee"]
    end

    subgraph L3["Couche 3 - Identite et acces"]
        direction LR
        AUTH["Authentik IdP<br/>OIDC SAML"]
        MFA["MFA TOTP<br/>Obligatoire admin"]
        RBAC["RBAC k8s<br/>Moindre privilege"]
    end

    subgraph L4["Couche 4 - Systeme"]
        direction LR
        HARD["Hardening CIS L1<br/>Ansible idempotent"]
        SSH["SSH par cle<br/>Pas de password"]
        UPD["Unattended upgrades<br/>Patch management"]
    end

    subgraph L5["Couche 5 - Application et donnees"]
        direction LR
        SEC["Secrets dans OpenBao<br/>Rotation automatique"]
        ENC["Chiffrement au repos<br/>Disques Azure"]
        ISO["NetworkPolicies k3s<br/>Pas de root container"]
    end

    Crown([Cible - Donnees Monero])

    subgraph L6["Couche 6 - Detection et reponse"]
        direction LR
        SIEM["Wazuh SIEM<br/>Correlation alertes"]
        SCAN["OpenVAS hebdo<br/>Lynis quotidien"]
        IR["Procedure incident<br/>Plan documente"]
    end

    Attacker ==> L1
    L1 ==> L2
    L2 ==> L3
    L3 ==> L4
    L4 ==> L5
    L5 ==> Crown

    L6 -.->|Surveille toutes les couches| Crown

    classDef layer1 fill:#FAECE7,stroke:#993C1D,color:#4A1B0C
    classDef layer2 fill:#FAEEDA,stroke:#854F0B,color:#412402
    classDef layer3 fill:#EEEDFE,stroke:#3C3489,color:#26215C
    classDef layer4 fill:#E1F5EE,stroke:#0F6E56,color:#04342C
    classDef layer5 fill:#E6F1FB,stroke:#185FA5,color:#042C53
    classDef layer6 fill:#FBEAF0,stroke:#993556,color:#4B1528
    classDef target fill:#FCEBEB,stroke:#A32D2D,color:#501313
    classDef ext fill:#F1EFE8,stroke:#444441,color:#2C2C2A

    class FW,IDS,GEO layer1
    class WAF,TLS,CRS layer2
    class AUTH,MFA,RBAC layer3
    class HARD,SSH,UPD layer4
    class SEC,ENC,ISO layer5
    class SIEM,SCAN,IR layer6
    class Crown target
    class Attacker ext
