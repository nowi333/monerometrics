flowchart LR
    subgraph Sources["Sources de donnees"]
        direction TB
        VM["VMs Ubuntu<br/>journald syslog auth"]
        K8S["Pods k3s<br/>Logs et metriques"]
        APP["Applications<br/>nginx monerod postgres"]
        FW["OPNsense<br/>Suricata fast log"]
    end

    subgraph Agents["Agents de collecte"]
        direction TB
        WzhA["Wazuh agent<br/>Logs securite et FIM"]
        Alloy["Grafana Alloy<br/>Logs applicatifs"]
        NodeE["node_exporter<br/>Metriques systeme"]
    end

    subgraph Backends["Stockage et traitement"]
        direction TB
        WzhM["Wazuh Manager<br/>Indexer Dashboard"]
        Loki["Loki<br/>Logs structures"]
        Prom["Prometheus<br/>Metriques timeseries"]
    end

    subgraph Visu["Visualisation et alerting"]
        direction TB
        Grafana["Grafana<br/>Dashboards unifies"]
        WzhD["Wazuh Dashboard<br/>Alertes securite"]
        AM["Alertmanager<br/>Routing alertes"]
    end

    Ops([SOC et SRE])

    VM --> WzhA
    VM --> Alloy
    VM --> NodeE
    K8S --> Alloy
    K8S --> NodeE
    APP --> Alloy
    FW --> WzhA

    WzhA -->|Port 1514| WzhM
    Alloy -->|HTTP push| Loki
    NodeE -->|Scrape 9100| Prom

    Loki --> Grafana
    Prom --> Grafana
    Prom --> AM
    WzhM --> WzhD

    Grafana -->|Visualise| Ops
    WzhD -->|Alertes critiques| Ops
    AM -->|Email Slack| Ops

    classDef src fill:#FAEEDA,stroke:#854F0B,color:#412402
    classDef agent fill:#E1F5EE,stroke:#0F6E56,color:#04342C
    classDef backend fill:#EEEDFE,stroke:#3C3489,color:#26215C
    classDef visu fill:#FBEAF0,stroke:#993556,color:#4B1528
    classDef ext fill:#E6F1FB,stroke:#185FA5,color:#042C53

    class VM,K8S,APP,FW src
    class WzhA,Alloy,NodeE agent
    class WzhM,Loki,Prom backend
    class Grafana,WzhD,AM visu
    class Ops ext
